<mvc:View controllerName="com.sap.mybankdetails.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <App id="app">
        <Page id="page" title="{i18n>appTitle}">
            <!-- <Page id="page" title="{i18n>title}"> -->
            <headerContent>
                <Button id="mbd_demoBtn" type="Emphasized" text="{i18n>homebtn}"></Button>
            </headerContent>
            <content>
                <!-- fragment include (xmlns:core="sap.ui.core" added) -->
                <core:Fragment id="mbd_frgBankDetailsFragment" fragmentName="com.sap.mybankdetails.view.fragments.BankDetails" type="XML" />
                <!-- // fragment include -->

                <Panel expandable="true" headerText="Card Details" width="auto" class="sapUiResponsiveMargin" id="mbd_panelAccountList">
                    <content>
                        <List id="myList" mode="MultiSelect" headerText="Inverted Info State" 
                        items="{ path: ''}">
                            <items>
                                <StandardListItem id="mbd_cardList" title="title" description="desc" icon="icon" iconInset="false" highlight="Success" info="info" infoState="Error" infoStateInverted="true" />
                            </items>
                        </List>
                    </content>
                </Panel>
            </content>
        </Page>
    </App>
</mvc:View>