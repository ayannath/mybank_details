<mvc:View controllerName="com.sap.mybankdetails.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <App id="app">
        <Page id="page" title="{i18n>title}">
            <headerContent>
                <Button id="mbd_demoBtn" type="Emphasized" text="{i18n>homebtn}" />
            </headerContent>
            <content>
                <!-- fragment include (xmlns:core="sap.ui.core" added) ("com.sap.mybankdetails" from manifest.json) -->
                <core:Fragment id="mbd_frgBankDetailsFragment" fragmentName="com.sap.mybankdetails.view.fragments.BankDetails" type="XML" />
                <core:Fragment id="mbd_frgCardDetailsFragment" fragmentName="com.sap.mybankdetails.view.fragments.CardDetails" type="XML" />
                <!-- // fragment include -->
            </content>
        </Page>
    </App>
</mvc:View>
